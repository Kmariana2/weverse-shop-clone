# Environment Variables for Weverse Shop Clone

# Database Configuration
# For local development with SQLite:
# DATABASE_URL="file:./dev.db"
#
# For production with PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/weverse_shop"
# DATABASE_URL="" # Leave empty for SQLite, set for PostgreSQL

# Node Environment
NODE_ENV="development"  # or "production"

# Next.js Public Variables
# Usually no need to set this for local dev (API uses relative paths)
# NEXT_PUBLIC_API_URL="http://localhost:3000"

# For production deployment on Vercel:
# Vercel automatically sets this to your production domain
# Only set if deploying elsewhere
# NEXT_PUBLIC_API_URL="https://your-domain.com"
