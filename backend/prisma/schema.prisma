// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(cuid())
  name          String
  price         Float
  images        String   // JSON array of image paths
  category      String
  badges        String   // JSON array: ["EXCLUSIVE", "LIMITED"]
  shippingTag   String   // "Shipped from US" or "Pre-order · Ships Jul 2026"
  stock         Int
  description   String
  sizes         String   // JSON array: ["S", "M", "L", "XL"]
  countdownEnd  DateTime
  createdAt     DateTime @default(now())

  cartItems CartItem[]
  orderItems OrderItem[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  cartItems CartItem[]
  orders    Order[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  size      String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, size])
}

model Order {
  id           String   @id @default(cuid())
  userId       String
  items        String   // JSON array of order items
  total        Float
  status       String   // "pending", "completed", "shipped"
  shippingInfo String   // JSON
  createdAt    DateTime @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  size      String
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}
